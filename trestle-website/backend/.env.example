# ============================================
# Trestle Reward System - Environment Variables
# ============================================

# ============================================
# WALLET CONNECT (Required)
# ============================================
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ============================================
# CONTRACT ADDRESSES (Required)
# ============================================
NEXT_PUBLIC_DISTRIBUTOR_ADDRESS=0xc77BDD46cD06C880609837a172BEA010daB19A12
NEXT_PUBLIC_BIOMETRIC_ADDRESS=0x8E3Dd0B0E261b16226E6DFBA080AEBb2431E2F44
NEXT_PUBLIC_REWARD_TOKEN=0xcF51ab7398315DbA6588Aa7fb3Df7c99D3D1F4dD

# ============================================
# RELAYER MODE: "biconomy" or "self-hosted"
# ============================================
RELAYER_MODE=self-hosted

# ============================================
# OPTION 1: BICONOMY (Easy Setup)
# ============================================
# Get free API key at: https://dashboard.biconomy.io
# Free tier: 100 transactions/day
# Starter: $9/mo for 10,000 tx/month
NEXT_PUBLIC_BICONOMY_API_KEY=your_biconomy_api_key_here

# ============================================
# OPTION 2: SELF-HOSTED RELAYER (Free, You Pay Gas)
# ============================================
# Private key for relayer wallet (needs MATIC for gas)
# ⚠️ NEVER commit this to git! Use .env.local only!
RELAYER_PRIVATE_KEY=your_relayer_private_key_here

# Polygon RPC URL
# Free: https://polygon-rpc.com/
# Alchemy: https://polygon-mainnet.g.alchemy.com/v2/your-key
RPC_URL=https://polygon-rpc.com/

# Verifier key (the address that signs claims)
# This should match PRIVATE_KEY in contracts/.env
VERIFIER_KEY=0xd1BCF94ef96564e4D51516dF039f333dE592c528