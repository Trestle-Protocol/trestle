# Environment variables for Hardhat configuration
# Copy this file to .env and fill in your actual values

# Polygon Network Configuration
POLYGON_RPC=https://polygon-rpc.com/  # Optional: defaults to public RPC if not set
PRIVATE_KEY=your_private_key_here  # Required for polygon network deployment

# Etherscan Configuration (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here  # Optional: needed for verification

# Other RPC URLs (if using different networks)
# MUMBAI_RPC=https://rpc-mumbai.maticvigil.com/  # Mumbai testnet

